package templates

import "github.com/claude/blog/internal/model"

type LoginData struct {
	Email   string
	ErrForm string
}

templ Login(cats []model.Category, theme string, d LoginData) {
	@Layout("Sign In", cats, "/login", theme) {
		<div class="auth-form">
			<h1>Sign In</h1>
			<form method="POST" action="/login" novalidate>
				if d.ErrForm != "" {
					<p class="form-error">{ d.ErrForm }</p>
				}
				<div class="form-group">
					<label for="email">Email</label>
					<input
						type="email"
						id="email"
						name="email"
						value={ d.Email }
						autocomplete="email"
						required
					/>
				</div>
				<div class="form-group">
					<label for="password">Password</label>
					<input
						type="password"
						id="password"
						name="password"
						autocomplete="current-password"
						required
					/>
				</div>
				<button type="submit">Sign In</button>
			</form>
			<p>Don't have an account? <a href="/register">Create one</a></p>
		</div>
	}
}
